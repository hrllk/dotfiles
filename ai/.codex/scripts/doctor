#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "$0")/.."

echo "Repository"
echo "  root: $(pwd)"
if git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  echo "  git: yes"
  echo "  branch: $(git branch --show-current 2>/dev/null || true)"
  echo "  status:"
  git status --short || true
else
  echo "  git: no"
fi

echo
echo "Harness"
for path in AGENTS.md CLAUDE.md README.md harness.yml .pre-commit-config.yaml .devcontainer/devcontainer.json scripts/bootstrap scripts/check scripts/test scripts/eval scripts/hooks; do
  if [[ -e "$path" ]]; then
    echo "  ok: $path"
  else
    echo "  missing: $path"
  fi
done

echo
echo "Tools"
for tool in rg git bash just pre-commit node npm pnpm yarn python3 uv ruff mypy pytest cargo; do
  if command -v "$tool" >/dev/null 2>&1; then
    echo "  ok: $tool"
  else
    echo "  missing: $tool"
  fi
done
